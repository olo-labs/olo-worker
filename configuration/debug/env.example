# Environment variables for Olo worker bootstrap (Unix/macOS).
# Copy to .env or source before running: source env.example
# See: docs/architecture/bootstrap/how-to-debug.md

# Worker region (comma-separated list of regions this instance serves)
export OLO_REGION=default

# Redis (use OLO_REDIS_URI for full URI, or host/port)
export OLO_REDIS_HOST=localhost
export OLO_REDIS_PORT=6379
# export OLO_REDIS_PASSWORD=
# export OLO_REDIS_URI=redis://localhost:6379

# PostgreSQL
export OLO_DB_HOST=localhost
export OLO_DB_PORT=5432
export OLO_DB_NAME=olo
export OLO_DB_USERNAME=olo
export OLO_DB_PASSWORD=pgpass
# Or full JDBC URL:
# export OLO_DB_URL=jdbc:postgresql://localhost:5432/olo

# Optional: Temporal (defaults in olo-defaults.properties)
# export OLO_TEMPORAL_TARGET=localhost:47233
# export OLO_TEMPORAL_NAMESPACE=default
# export OLO_TEMPORAL_TASK_QUEUE=olo-chat-queue-ollama

# Optional: bootstrap timeout (seconds; 0 = wait forever for Redis/snapshot)
# export OLO_BOOTSTRAP_CONFIG_WAIT_TIMEOUT_SECONDS=0
